{
  "name": "skystock",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:worker": "wrangler pages dev --compatibility-date=2024-01-01 -- vite",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:init": "wrangler d1 execute skystock-db --local --file=./db/schema.sql",
    "db:init:remote": "wrangler d1 execute skystock-db --remote --file=./db/schema.sql"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.2.0",
    "@paypal/react-paypal-js": "^8.1.0",
    "@types/three": "^0.184.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.4.0",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.23.0",
    "resend": "^3.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "wrangler": "^3.57.0"
  }
}
